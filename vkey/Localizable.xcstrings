    "Minimal formatting such as removing fillers and adding punctuation.\nExample: \"um, so we meet at 10 tomorrow\" → \"We meet at 10 tomorrow.\"" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フィラー除去と句読点の補完など、最小限の整形をします。\n例: 「えーと、明日は10時集合で」→「明日は10時集合で。」"
          }
        }
      }
    },
